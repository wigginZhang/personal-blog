---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="About" description="About this blog">
  <section class="content-section">
    <div class="content">
      <a href="/" class="back-link">&larr; Back to Home</a>
      <h1 class="page-title">About</h1>
      <div class="about-content">
        <p>Welcome to my personal blog! This is a space where I share technical thoughts, learning experiences, and interesting findings from my work and life.</p>
        <p>This blog is built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> and deployed on GitHub Pages. I write about various topics including web development, programming, tools, and productivity.</p>
        <p>Feel free to explore the articles and reach out if you have any questions or suggestions.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .content-section {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-lg);
    padding-top: calc(60px + var(--space-3xl));
  }

  .content {
    background: var(--bg-card);
    border-radius: 12px;
    padding: var(--space-2xl);
    box-shadow: var(--shadow-sm);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
    line-height: 1.2;
  }

  .about-content {
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .about-content p {
    margin-bottom: var(--space-md);
  }

  .about-content a {
    color: var(--accent);
    text-decoration: underline;
  }

  .about-content a:hover {
    text-decoration: none;
  }
</style>